<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_darkest">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_dark"
        android:paddingHorizontal="6dp"
        android:paddingVertical="6dp">

        <ImageButton
            android:id="@+id/btnNotepadBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:tint="@color/text_bright"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNotepadTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_bright"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:singleLine="true"
                android:ellipsize="end"
                android:text="Note"/>

            <TextView
                android:id="@+id/tvNotepadFooter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_dim"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:singleLine="true"
                android:ellipsize="end"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnNotepadSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:text="Save"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="13sp"
            android:minHeight="0dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:background="@drawable/btn_primary"/>
    </LinearLayout>

    <EditText
        android:id="@+id/edNotepadBody"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="14dp"
        android:gravity="top|start"
        android:background="@color/bg_input"
        android:textColor="@color/text_bright"
        android:textColorHint="@color/text_dim"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:hint="Note shared with this device. Both sides can edit; tap Save to send."
        android:inputType="textMultiLine|textNoSuggestions|textCapSentences"
        android:scrollbars="vertical"
        android:importantForAutofill="no"/>
</LinearLayout>
