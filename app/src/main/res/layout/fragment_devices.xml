<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_darkest">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:background="@drawable/bg_panel">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Max devices online"
            android:textColor="@color/text"
            android:textSize="13sp"/>

        <Button
            android:id="@+id/btnMaxMinus"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="−"
            android:textSize="18sp"
            android:textColor="@color/text_bright"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:background="@drawable/btn_secondary"/>

        <TextView
            android:id="@+id/tvMaxValue"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/text_bright"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:text="—"/>

        <Button
            android:id="@+id/btnMaxPlus"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="+"
            android:textSize="18sp"
            android:textColor="@color/text_bright"
            android:padding="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:background="@drawable/btn_secondary"/>

        <Button
            android:id="@+id/btnDevicesRefresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="↻"
            android:textColor="@color/text"
            android:textSize="14sp"
            android:minHeight="0dp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:background="@drawable/btn_secondary"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvDevicesEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:gravity="center"
        android:text="No authorized devices yet."
        android:textColor="@color/text_dim"
        android:textSize="13sp"
        android:visibility="gone"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/devicesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"/>
    </ScrollView>
</LinearLayout>
