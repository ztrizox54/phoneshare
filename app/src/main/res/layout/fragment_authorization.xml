<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="14dp"
    android:background="@color/bg_darkest">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STORAGE ACCESS"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvStorageStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/text"
            android:textSize="13sp"/>

        <Button
            android:id="@+id/btnGrantStorage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Grant full storage access"
            android:textColor="@color/text"
            android:background="@drawable/btn_secondary"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="22dp"
            android:background="@color/border"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DEVICE AUTHORIZATION"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="A device asks for access by scanning the QR code shown on its browser, or by typing in the 6-character code under it."
            android:textColor="@color/text"
            android:textSize="13sp"/>

        <Button
            android:id="@+id/btnAuthCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Enter device authorization code"
            android:textColor="@color/text"
            android:background="@drawable/btn_secondary"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="22dp"
            android:background="@color/border"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="STRANGERS WAITING"
                android:textColor="@color/orange"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>
            <Button
                android:id="@+id/btnRefreshStrangers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↻"
                android:textColor="@color/text"
                android:textSize="14sp"
                android:minHeight="0dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:background="@drawable/btn_secondary"/>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:text="Devices that opened the auth page but haven't been approved yet. Each request lasts 5 minutes."/>

        <TextView
            android:id="@+id/tvStrangersEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:padding="14dp"
            android:gravity="center"
            android:text="No-one is waiting."
            android:textColor="@color/text_dim"
            android:textSize="13sp"
            android:fontFamily="monospace"/>

        <LinearLayout
            android:id="@+id/strangersList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="6dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textSize="12sp"
            android:textColor="@color/text_dim"
            android:text="Sessions auto-renew for up to 30 days. Per-device settings (role, allowed folders, approval requirements) are remembered across sessions and editable in Devices."/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="22dp"
            android:background="@color/border"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DANGER ZONE"
            android:textColor="@color/red"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/text"
            android:textSize="13sp"
            android:text="Wipe everything: sessions, remembered devices, shared notes, activity log. After this, every device will need to re-authorize from scratch."/>

        <Button
            android:id="@+id/btnClearAllData"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Clear all device data"
            android:textColor="@color/red"
            android:textStyle="bold"
            android:background="@drawable/btn_danger"/>
    </LinearLayout>
</ScrollView>
