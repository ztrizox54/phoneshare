<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_terminal"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/strCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/orange"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.15"
            android:text="ABC234"/>

        <TextView
            android:id="@+id/strAge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:textColor="@color/text_dim"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:text="0s ago · 5m left"/>
    </LinearLayout>

    <TextView
        android:id="@+id/strDevice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/text"
        android:textSize="12sp"
        android:singleLine="true"
        android:ellipsize="end"
        android:text="Chrome on Windows · 192.168.1.10"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp">

        <Button
            android:id="@+id/strApprove"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Approve…"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="12sp"
            android:minHeight="0dp"
            android:paddingVertical="8dp"
            android:background="@drawable/btn_primary"/>

        <Button
            android:id="@+id/strDeny"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Deny"
            android:textColor="@color/red"
            android:textStyle="bold"
            android:textSize="12sp"
            android:minHeight="0dp"
            android:paddingVertical="8dp"
            android:background="@drawable/btn_danger"/>
    </LinearLayout>
</LinearLayout>
