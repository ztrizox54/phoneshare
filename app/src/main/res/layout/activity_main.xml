<?xml version="1.0" encoding="utf-8"?>
<com.phoneshare.app.WideDrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_darkest">

        <!-- Custom topbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/bg_dark"
            android:paddingHorizontal="6dp"
            android:paddingVertical="6dp">

            <ImageButton
                android:id="@+id/btnDrawerToggle"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Open navigation"
                android:tint="@color/text_bright"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="&gt;_"
                android:textColor="@color/accent"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/tvTopbarTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Server"
                android:textColor="@color/text_bright"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:singleLine="true"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Fragment container -->
        <FrameLayout
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>
    </LinearLayout>

    <!-- Sidebar drawer -->
    <LinearLayout
        android:layout_width="260dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@color/bg_dark"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="6dp"
            android:paddingVertical="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&gt;_"
                android:textColor="@color/accent"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="monospace"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="PhoneShare"
                android:textColor="@color/text_bright"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="-0.02"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="6dp"
            android:background="@color/border"/>

        <LinearLayout
            android:id="@+id/navServer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="11dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_nav_item"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="22dp"
                android:layout_height="wrap_content"
                android:text="●"
                android:textColor="@color/accent"
                android:textSize="14sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Server"
                android:textColor="@color/text"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAuth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="11dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_nav_item"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="22dp"
                android:layout_height="wrap_content"
                android:text="🔑"
                android:textSize="14sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Authorization"
                android:textColor="@color/text"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navDevices"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="11dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_nav_item"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="22dp"
                android:layout_height="wrap_content"
                android:text="📱"
                android:textSize="14sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Devices"
                android:textColor="@color/text"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/navDevicesBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="1dp"
                android:textColor="#fff"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:background="@drawable/status_dot_red"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="11dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_nav_item"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="22dp"
                android:layout_height="wrap_content"
                android:text="📝"
                android:textSize="14sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Shared notes"
                android:textColor="@color/text"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/navNotesBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="1dp"
                android:textColor="#fff"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:background="@drawable/status_dot_red"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="11dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_nav_item"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="22dp"
                android:layout_height="wrap_content"
                android:text="⚙"
                android:textSize="14sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Permissions"
                android:textColor="@color/text"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/navSettingsBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:paddingVertical="1dp"
                android:textColor="#fff"
                android:textSize="10sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:background="@drawable/status_dot_red"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="11dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_nav_item"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="22dp"
                android:layout_height="wrap_content"
                android:text="📜"
                android:textSize="14sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Activity log"
                android:textColor="@color/text"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/tvDrawerFooter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:textColor="@color/text_dim"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:text="server: stopped"/>
    </LinearLayout>
</com.phoneshare.app.WideDrawerLayout>
